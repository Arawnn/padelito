APP_NAME=Padelito
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001
FRONTEND_URL=http://localhost:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=padelito
DB_USERNAME=padelito
DB_PASSWORD=change-me-local
DB_SSLMODE=disable
DB_SEARCH_PATH=public
POSTGRES_PORT=5432
DB_TEST_HOST=postgres
DB_TEST_PORT=5432
DB_TEST_DATABASE=padelito_test
DB_TEST_USERNAME=padelito
DB_TEST_PASSWORD=change-me-local

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_PORT_FORWARD=6379

CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
QUEUE_CONNECTION=redis

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=hello@padelito.local
MAIL_FROM_NAME="${APP_NAME}"
MAILPIT_UI_PORT=8025

FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=padelito
AWS_SECRET_ACCESS_KEY=change-me-local
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=padelito
AWS_ENDPOINT=http://minio:9000
AWS_URL=http://localhost:9000/padelito
AWS_USE_PATH_STYLE_ENDPOINT=true
MINIO_ROOT_USER=padelito
MINIO_ROOT_PASSWORD=change-me-local
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

APP_PORT=8001
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
PROMETHEUS_PORT=9090
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318

SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0

DOCKER_UID=1000
DOCKER_GID=1000
