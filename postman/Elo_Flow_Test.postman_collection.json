    {
      "name": "17 - GET match : vérification ELO snapshot",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const match = pm.response.json().data;",
              "",
              "// ─── Statut ───────────────────────────────────────────────",
              "pm.test('Match validé', () => pm.expect(match.status).to.eql('validated'));",
              "",
              "// ─── Score ────────────────────────────────────────────────",
              "pm.test('Score Team A = 2', () => pm.expect(match.score.team_a).to.eql(2));",
              "pm.test('Score Team B = 1', () => pm.expect(match.score.team_b).to.eql(1));",
              "",
              "// ─── ELO snapshot ─────────────────────────────────────────",
              "// Tous débutants : K=40, Elos 1500/1500, sets 2-1 → multiplier 1.0",
              "// expectedA = 0.5 → changeA = round(40 * (1-0.5) * 1.0) = +20",
              "pm.test('ELO avant Team A = 1500', () => pm.expect(match.elo.team_a_before).to.eql(1500));",
              "pm.test('ELO avant Team B = 1500', () => pm.expect(match.elo.team_b_before).to.eql(1500));",
              "pm.test('ELO change Team A = +20', () => pm.expect(match.elo.change).to.eql(20));",
              "",
              "// ─── Tous confirmés ───────────────────────────────────────",
              "pm.test('4 joueurs confirmés', () => pm.expect(match.confirmed_player_ids).to.have.lengthOf(4));"
            ]
          }
        }
      ],
      "request": {
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token_p1}}", "type": "string" }] },
        "method": "GET",
        "header": [{ "key": "Accept", "value": "application/json" }],
        "url": {
