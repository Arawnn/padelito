    {
      "name": "01 - Register P1",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Génère un timestamp unique pour éviter les conflits d'email",
              "pm.collectionVariables.set('_ts', Date.now());"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "const json = pm.response.json();",
              "pm.test('Token présent', () => pm.expect(json.token).to.be.a('string').and.not.empty);",
              "pm.collectionVariables.set('token_p1', json.token);",
              "// player_id = data.user.id (profil auto-créé par RegisterPlayerCommandHandler)",
              "pm.collectionVariables.set('player_id_p1', json.data.user.id);"
            ]
          }
        }
      ],
      "request": {
        "auth": { "type": "noauth" },
        "method": "POST",
        "header": [
          { "key": "Accept",       "value": "application/json" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Player One\",\n  \"email\": \"p1_{{_ts}}@test.padelito\",\n  \"password\": \"Test@123456!\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/api/v1/register",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "register"]
        }
      }
