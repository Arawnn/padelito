    {
      "name": "12 - P1 met à jour le score (Team A gagne 2-1)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const match = pm.response.json().data;",
              "const sets = match.score.sets_detail;",
              "pm.test('sets_detail enregistré (3 sets)', () => pm.expect(sets).to.have.lengthOf(3));",
              "// score.team_a/b est null jusqu'à finalize() (4e confirmation)",
              "// On vérifie les sets gagnés en dérivant depuis sets_detail",
              "const setsWonA = sets.filter(s => s.a > s.b).length;",
              "const setsWonB = sets.filter(s => s.b > s.a).length;",
              "pm.test('Team A gagne 2 sets', () => pm.expect(setsWonA).to.eql(2));",
              "pm.test('Team B gagne 1 set',  () => pm.expect(setsWonB).to.eql(1));"
            ]
          }
        }
      ],
      "request": {
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token_p1}}", "type": "string" }] },
