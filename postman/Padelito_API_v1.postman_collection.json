						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"user@example.com\",\n  \"token\": \"token-from-email\",\n  \"password\": \"newpassword12345\",\n  \"password_confirmation\": \"newpassword12345\"\n}\n",
							"options": {
								"raw": {
									"language": "json"
								}
							}
